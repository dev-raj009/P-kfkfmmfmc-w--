# ── PW Portal Security ──────────────────────────────────
Options -Indexes -ExecCGI

# Block direct access to includes folder
<FilesMatch "\.(php|json)$">
  <If "%{REQUEST_URI} =~ m#/includes/#">
    Require all denied
  </If>
  <If "%{REQUEST_URI} =~ m#/data/#">
    Require all denied
  </If>
</FilesMatch>

# Block data folder entirely
<DirectoryMatch "^.*/data/">
  Require all denied
</DirectoryMatch>

# Block includes folder entirely  
<DirectoryMatch "^.*/includes/">
  Require all denied
</DirectoryMatch>

# Hide server info
ServerSignature Off

# Security headers
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# PHP settings
<IfModule mod_php.c>
  php_flag display_errors Off
  php_flag log_errors On
</IfModule>

# Rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redirect http to https (uncomment on production with SSL)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Default to index.php
  RewriteRule ^$ index.php [L]
</IfModule>

